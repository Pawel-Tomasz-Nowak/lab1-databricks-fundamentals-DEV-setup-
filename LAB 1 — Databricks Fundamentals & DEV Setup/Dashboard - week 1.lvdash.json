{
  "datasets": [
    {
      "name": "dad5a1ae",
      "displayName": "Alabama Residential Property Sales Overview",
      "queryLines": [
        "USE CATALOG `dbr_dev`;\n",
        "USE SCHEMA `pawelnowak2004pri219`;\n",
        "\n",
        "SELECT type, soldOn, lastSoldPrice, beds, baths FROM dbr_dev.pawelnowak2004pri219.alabama_real_estate"
      ]
    },
    {
      "name": "4d1fd514",
      "displayName": "Cumulative Revenue from Sold Houses by Property Size Over Time",
      "queryLines": [
        "\n",
        "WITH daily_revenue AS (\n",
        "  SELECT \n",
        "    `soldOn` as sale_date,\n",
        "    CASE \n",
        "      WHEN `sqft` < 1500 THEN 'Small (< 1,500 sqft)'\n",
        "      WHEN `sqft` >= 1500 AND `sqft` < 2500 THEN 'Medium (1,500-2,500 sqft)'\n",
        "      WHEN `sqft` >= 2500 AND `sqft` < 3500 THEN 'Large (2,500-3,500 sqft)'\n",
        "      WHEN `sqft` >= 3500 THEN 'Extra Large (3,500+ sqft)'\n",
        "    END as size_category,\n",
        "    SUM(`lastSoldPrice`) as daily_revenue\n",
        "  FROM `dbr_dev`.`pawelnowak2004pri219`.`alabama_real_estate`\n",
        "  WHERE `sqft` IS NOT NULL \n",
        "    AND `lastSoldPrice` IS NOT NULL \n",
        "    AND `soldOn` IS NOT NULL\n",
        "  GROUP BY `soldOn`, size_category\n",
        "),\n",
        "cumulative_revenue AS (\n",
        "  SELECT \n",
        "    sale_date,\n",
        "    size_category,\n",
        "    daily_revenue,\n",
        "    SUM(daily_revenue) OVER (\n",
        "      PARTITION BY size_category \n",
        "      ORDER BY sale_date \n",
        "      ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW\n",
        "    ) as cumulative_revenue\n",
        "  FROM daily_revenue\n",
        ")\n",
        "SELECT \n",
        "  sale_date,\n",
        "  size_category,\n",
        "  cumulative_revenue\n",
        "FROM cumulative_revenue\n",
        "ORDER BY sale_date, size_category\n"
      ]
    }
  ],
